# Copy this file to terraform.tfvars and fill in your own values.
# terraform.tfvars is gitignored - never commit real secrets.

github_org  = "your-github-username-or-org"
github_repo = "your-repo-name"

# Optional - paste your SonarCloud token here (step 3 of the README),
# or leave empty and add it later with the AWS CLI (step 4).
# sonarcloud_token = "paste-your-sonarcloud-token-here"
