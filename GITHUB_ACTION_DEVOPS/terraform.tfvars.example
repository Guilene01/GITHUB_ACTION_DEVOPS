# Copy this file to terraform.tfvars and fill in the values below.
# terraform.tfvars contains sensitive data and must never be committed to git.

# ── AWS ───────────────────────────────────────────────────────────────────────
aws_region               = "us-east-1"  # change to your preferred region
profile                  = "default"    # AWS CLI profile name
aws_instance_type_server = "t2.large"

# ── GitHub OIDC (REQUIRED) ────────────────────────────────────────────────────
# These scope the IAM role so only your repo's main branch can assume it via OIDC.
github_org  = "your-github-username-or-org"
github_repo = "your-repo-name"

# ── JFrog & Vault (fill in AFTER terraform apply) ─────────────────────────────
# JFrog Artifactory is installed on the server by Terraform — no token needed upfront.
# After the server is running, log into the JFrog UI (:8082), set the admin password,
# and generate an access token. Then update HashiCorp Vault manually (see README).
#
# jfrog_secret_username_and_password = ["admin", "your-strong-password"]
# jfrog_secret_token                 = "your-jfrog-access-token"
